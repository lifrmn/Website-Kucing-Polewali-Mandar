'use client'

import { useEffect, useState } from 'react'
import { orderService } from '@/services/orderService'
import { Search, Loader2, Eye, CheckCircle, XCircle, Clock, Image as ImageIcon, X } from 'lucide-react'
import { toast } from 'react-toastify'
import Image from 'next/image'

interface Order {
  id: string
  order_number: string
  customer_name: string
  customer_email: string
  customer_phone: string
  customer_address?: string
  order_type: string
  total_amount: number
  payment_method: string
  payment_status: 'pending' | 'paid' | 'failed'
  payment_proof_url?: string | null
  order_status: 'pending' | 'confirmed' | 'processing' | 'completed' | 'cancelled'
  created_at: Date | string
  notes?: string
  items?: any[]
}

export default function AdminOrdersPage() {
  const [orders, setOrders] = useState<Order[]>([])
  const [filteredOrders, setFilteredOrders] = useState<Order[]>([])
  const [loading, setLoading] = useState(true)
  const [searchQuery, setSearchQuery] = useState('')
  const [statusFilter, setStatusFilter] = useState('all')
  const [selectedOrder, setSelectedOrder] = useState<Order | null>(null)
  const [showDetailModal, setShowDetailModal] = useState(false)
  const [showPaymentProofModal, setShowPaymentProofModal] = useState(false)
  const [paymentProofUrl, setPaymentProofUrl] = useState<string | null>(null)
  const [updateLoading, setUpdateLoading] = useState(false)

  useEffect(() => {
    loadOrders()
  }, [])

  useEffect(() => {
    let filtered = [...orders]

    // Search filter
    if (searchQuery) {
      filtered = filtered.filter(order => 
        order.order_number.toLowerCase().includes(searchQuery.toLowerCase()) ||
        order.customer_name.toLowerCase().includes(searchQuery.toLowerCase()) ||
        order.customer_email.toLowerCase().includes(searchQuery.toLowerCase())
      )
    }

    // Status filter
    if (statusFilter !== 'all') {
      filtered = filtered.filter(order => order.order_status === statusFilter)
    }

    setFilteredOrders(filtered)
  }, [searchQuery, statusFilter, orders])

  const loadOrders = async () => {
    setLoading(true)
    const response = await orderService.getOrders()
    if (response.success && response.data) {
      setOrders(response.data.data || [])
      setFilteredOrders(response.data.data || [])
    }
    setLoading(false)
  }

  const handleUpdatePaymentStatus = async (orderId: string, newStatus: 'pending' | 'paid' | 'failed') => {
    const statusText = {
      pending: 'Menunggu Pembayaran',
      paid: 'Lunas',
      failed: 'Gagal'
    }

    if (!confirm(`Konfirmasi: Ubah status pembayaran menjadi "${statusText[newStatus]}"?`)) return

    setUpdateLoading(true)
    const response = await orderService.updatePaymentStatus(orderId, newStatus)
    
    if (response.success) {
      toast.success(response.message || `Status pembayaran berhasil diubah menjadi ${statusText[newStatus]}`)
      await loadOrders()
      // Update selected order if modal is open
      if (selectedOrder && selectedOrder.id === orderId) {
        const updatedOrder = { ...selectedOrder, payment_status: newStatus }
        if (newStatus === 'paid') {
          updatedOrder.order_status = 'confirmed'
        }
        setSelectedOrder(updatedOrder)
      }
    } else {
      toast.error(response.error || 'Gagal mengubah status pembayaran')
    }
    setUpdateLoading(false)
  }

  const handleUpdateOrderStatus = async (orderId: string, newStatus: 'pending' | 'confirmed' | 'processing' | 'completed' | 'cancelled') => {
    const statusText = {
      pending: 'Menunggu',
      confirmed: 'Dikonfirmasi',
      processing: 'Diproses',
      completed: 'Selesai',
      cancelled: 'Dibatalkan'
    }

    if (!confirm(`Konfirmasi: Ubah status pesanan menjadi "${statusText[newStatus]}"?`)) return

    setUpdateLoading(true)
    const response = await orderService.updateOrderStatus(orderId, newStatus)
    
    if (response.success) {
      toast.success(response.message || `Status pesanan berhasil diubah menjadi ${statusText[newStatus]}`)
      await loadOrders()
      // Update selected order if modal is open
      if (selectedOrder && selectedOrder.id === orderId) {
        setSelectedOrder({ ...selectedOrder, order_status: newStatus })
      }
    } else {
      toast.error(response.error || 'Gagal mengubah status pesanan')
    }
    setUpdateLoading(false)
  }

  const handleViewPaymentProof = (order: Order) => {
    if (order.payment_proof_url) {
      setPaymentProofUrl(order.payment_proof_url)
      setShowPaymentProofModal(true)
    } else {
      toast.info('Bukti pembayaran belum diunggah')
    }
  }

  const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0,
    }).format(amount)
  }

  const formatDate = (date: Date | string) => {
    const d = new Date(date)
    return new Intl.DateTimeFormat('id-ID', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    }).format(d)
  }

  const getStatusBadge = (status: string) => {
    const badges = {
      pending: { color: 'bg-yellow-100 text-yellow-700 border-yellow-300', icon: <Clock className="w-3 h-3" />, text: 'Menunggu' },
      confirmed: { color: 'bg-blue-100 text-blue-700 border-blue-300', icon: <CheckCircle className="w-3 h-3" />, text: 'Dikonfirmasi' },
      processing: { color: 'bg-purple-100 text-purple-700 border-purple-300', icon: <Clock className="w-3 h-3" />, text: 'Diproses' },
      completed: { color: 'bg-green-100 text-green-700 border-green-300', icon: <CheckCircle className="w-3 h-3" />, text: 'Selesai' },
      cancelled: { color: 'bg-red-100 text-red-700 border-red-300', icon: <XCircle className="w-3 h-3" />, text: 'Dibatalkan' },
    }
    const badge = badges[status as keyof typeof badges] || badges.pending
    return (
      <span className={`inline-flex items-center gap-1 sm:gap-2 px-2 sm:px-3 py-1 rounded-full text-xs font-bold border-2 ${badge.color} whitespace-nowrap`}>
        {badge.icon}
        <span className="hidden sm:inline">{badge.text}</span>
        <span className="sm:hidden">{badge.text.slice(0, 3)}</span>
      </span>
    )
  }

  const getPaymentBadge = (status: string) => {
    const badges = {
      pending: { color: 'bg-yellow-100 text-yellow-700', text: '⏳ Belum Bayar', shortText: '⏳' },
      paid: { color: 'bg-green-100 text-green-700', text: '✅ Lunas', shortText: '✅' },
      failed: { color: 'bg-red-100 text-red-700', text: '❌ Gagal', shortText: '❌' },
    }
    const badge = badges[status as keyof typeof badges] || badges.pending
    return (
      <span className={`inline-flex items-center px-2 sm:px-3 py-1 rounded-lg text-xs font-bold ${badge.color} whitespace-nowrap`}>
        <span className="hidden sm:inline">{badge.text}</span>
        <span className="sm:hidden">{badge.shortText}</span>
      </span>
    )
  }

  if (loading) {
    return (
      <div className="flex items-center justify-center h-screen">
        <div className="text-center">
          <Loader2 className="w-12 h-12 animate-spin text-purple-600 mx-auto mb-4" />
          <p className="text-gray-600 font-semibold">Memuat pesanan...</p>
        </div>
      </div>
    )
  }

  return (
    <div className="space-y-4 sm:space-y-6">
      {/* Header */}
      <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h1 className="text-2xl sm:text-3xl font-bold text-gray-800 break-words">Kelola Pesanan</h1>
          <p className="text-sm sm:text-base text-gray-600 break-words">Manage and track all customer orders</p>
        </div>
        <div className="flex items-center gap-4">
          <div className="text-center sm:text-right">
            <p className="text-xs sm:text-sm text-gray-600">Total Pesanan</p>
            <p className="text-2xl sm:text-3xl font-bold text-purple-600">{orders.length}</p>
          </div>
        </div>
      </div>

      {/* Filters */}
      <div className="bg-white rounded-lg sm:rounded-xl p-3 sm:p-4 shadow-lg">
        <div className="grid sm:grid-cols-2 gap-3 sm:gap-4">
          {/* Search */}
          <div className="relative">
            <Search className="absolute w-4 h-4 text-gray-400 pointer-events-none" style={{left: '16px', top: '50%', transform: 'translateY(-50%)'}} />
            <input
              type="text"
              placeholder="Cari nomor pesanan, nama..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="w-full pl-10 pr-4 py-3 text-base border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 hover:border-purple-300 transition-all"
            />
          </div>

          {/* Status Filter */}
          <div>
            <select
              value={statusFilter}
              onChange={(e) => setStatusFilter(e.target.value)}
              className="w-full px-3 sm:px-4 py-2 sm:py-3 text-sm sm:text-base border-2 border-gray-200 rounded-lg sm:rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all bg-white font-semibold"
            >
              <option value="all">Semua Status</option>
              <option value="pending">Menunggu</option>
              <option value="confirmed">Dikonfirmasi</option>
              <option value="processing">Diproses</option>
              <option value="completed">Selesai</option>
              <option value="cancelled">Dibatalkan</option>
            </select>
          </div>
        </div>
      </div>

      {/* Stats Cards */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        {[
          { label: 'Menunggu', value: orders.filter(o => o.order_status === 'pending').length, color: 'yellow' },
          { label: 'Dikonfirmasi', value: orders.filter(o => o.order_status === 'confirmed').length, color: 'blue' },
          { label: 'Diproses', value: orders.filter(o => o.order_status === 'processing').length, color: 'purple' },
          { label: 'Selesai', value: orders.filter(o => o.order_status === 'completed').length, color: 'green' },
        ].map((stat) => (
          <div key={stat.label} className="bg-white rounded-lg sm:rounded-xl p-3 sm:p-4 shadow-lg">
            <p className="text-xs sm:text-sm text-gray-600 mb-1 break-words">{stat.label}</p>
            <p className={`text-2xl sm:text-3xl font-bold text-${stat.color}-600`}>{stat.value}</p>
          </div>
        ))}
      </div>

      {/* Orders Table */}
      <div className="bg-white rounded-lg sm:rounded-xl shadow-lg overflow-hidden">
        <div className="overflow-x-auto min-w-full">
          <table className="w-full min-w-[900px]">
            <thead className="bg-gray-50">
              <tr>
                <th className="px-3 sm:px-6 py-3 sm:py-4 text-left text-xs font-bold text-gray-600 uppercase whitespace-nowrap">Order #</th>
                <th className="px-3 sm:px-6 py-3 sm:py-4 text-left text-xs font-bold text-gray-600 uppercase whitespace-nowrap">Customer</th>
                <th className="px-3 sm:px-6 py-3 sm:py-4 text-left text-xs font-bold text-gray-600 uppercase whitespace-nowrap">Tanggal</th>
                <th className="px-3 sm:px-6 py-3 sm:py-4 text-left text-xs font-bold text-gray-600 uppercase whitespace-nowrap">Total</th>
                <th className="px-3 sm:px-6 py-3 sm:py-4 text-left text-xs font-bold text-gray-600 uppercase whitespace-nowrap">Pembayaran</th>
                <th className="px-3 sm:px-6 py-3 sm:py-4 text-left text-xs font-bold text-gray-600 uppercase whitespace-nowrap">Bukti</th>
                <th className="px-3 sm:px-6 py-3 sm:py-4 text-left text-xs font-bold text-gray-600 uppercase whitespace-nowrap">Status</th>
                <th className="px-3 sm:px-6 py-3 sm:py-4 text-right text-xs font-bold text-gray-600 uppercase whitespace-nowrap">Aksi</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-gray-200">
              {filteredOrders.map((order) => (
                <tr key={order.id} className="hover:bg-gray-50 transition-colors">
                  <td className="px-3 sm:px-6 py-3 sm:py-4">
                    <span className="font-bold text-purple-600 text-sm break-all">#{order.order_number}</span>
                  </td>
                  <td className="px-3 sm:px-6 py-3 sm:py-4">
                    <div className="min-w-0">
                      <p className="font-bold text-gray-800 text-sm sm:text-base break-words">{order.customer_name}</p>
                      <p className="text-xs sm:text-sm text-gray-500 break-all">{order.customer_email}</p>
                    </div>
                  </td>
                  <td className="px-3 sm:px-6 py-3 sm:py-4">
                    <span className="text-xs sm:text-sm text-gray-600 whitespace-nowrap">{formatDate(order.created_at)}</span>
                  </td>
                  <td className="px-3 sm:px-6 py-3 sm:py-4">
                    <span className="font-bold text-gray-800 text-sm sm:text-base whitespace-nowrap">{formatCurrency(order.total_amount)}</span>
                  </td>
                  <td className="px-3 sm:px-6 py-3 sm:py-4">
                    {getPaymentBadge(order.payment_status)}
                  </td>
                  <td className="px-3 sm:px-6 py-3 sm:py-4">
                    {order.payment_proof_url ? (
                      <button
                        onClick={() => handleViewPaymentProof(order)}
                        className="p-1.5 sm:p-2 bg-blue-100 hover:bg-blue-200 text-blue-600 rounded-lg transition-all text-sm"
                        title="Lihat bukti pembayaran"
                      >
                        <ImageIcon className="w-4 h-4" />
                      </button>
                    ) : (
                      <span className="text-xs text-gray-400 whitespace-nowrap">Belum upload</span>
                    )}
                  </td>
                  <td className="px-3 sm:px-6 py-3 sm:py-4">
                    {getStatusBadge(order.order_status)}
                  </td>
                  <td className="px-3 sm:px-6 py-3 sm:py-4 text-right">
                    <button
                      onClick={() => {
                        setSelectedOrder(order)
                        setShowDetailModal(true)
                      }}
                      className="p-1.5 sm:p-2 bg-purple-100 hover:bg-purple-200 text-purple-600 rounded-lg transition-all inline-flex items-center gap-1 sm:gap-2 text-xs sm:text-sm font-semibold whitespace-nowrap"
                    >
                      <Eye className="w-4 h-4" />
                      <span className="hidden sm:inline">Detail</span>
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* Detail Modal */}
      {showDetailModal && selectedOrder && (
        <div className="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-2 sm:p-4">
          <div className="bg-white rounded-xl sm:rounded-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto animate-fadeInUp">
            <div className="p-4 sm:p-6 border-b border-gray-200 bg-gradient-to-r from-purple-600 to-blue-600">
              <div className="flex items-center justify-between">
                <div>
                  <h2 className="text-lg sm:text-2xl font-bold text-white break-words">Detail Pesanan #{selectedOrder.order_number}</h2>
                  <p className="text-purple-100 text-xs sm:text-sm mt-1">{formatDate(selectedOrder.created_at)}</p>
                </div>
                <button
                  onClick={() => setShowDetailModal(false)}
                  className="text-white hover:text-purple-200 text-2xl sm:text-3xl transition-all flex-shrink-0"
                >
                  ×
                </button>
              </div>
            </div>

            <div className="p-4 sm:p-6 space-y-4 sm:space-y-6">
              {/* Customer Info */}
              <div className="bg-gray-50 rounded-lg sm:rounded-xl p-3 sm:p-4">
                <h3 className="text-base sm:text-lg font-bold text-gray-800 mb-2 sm:mb-3 flex items-center gap-2">
                  👤 Informasi Customer
                </h3>
                <div className="grid sm:grid-cols-2 gap-3 sm:gap-4">
                  <div>
                    <p className="text-xs sm:text-sm text-gray-600">Nama</p>
                    <p className="font-semibold text-sm sm:text-base text-gray-800 break-words">{selectedOrder.customer_name}</p>
                  </div>
                  <div>
                    <p className="text-xs sm:text-sm text-gray-600">Email</p>
                    <p className="font-semibold text-sm sm:text-base text-gray-800 break-all">{selectedOrder.customer_email}</p>
                  </div>
                  <div>
                    <p className="text-xs sm:text-sm text-gray-600">Telepon</p>
                    <p className="font-semibold text-sm sm:text-base text-gray-800">{selectedOrder.customer_phone}</p>
                  </div>
                  {selectedOrder.customer_address && (
                    <div>
                      <p className="text-xs sm:text-sm text-gray-600">Alamat</p>
                      <p className="font-semibold text-sm sm:text-base text-gray-800 break-words">{selectedOrder.customer_address}</p>
                    </div>
                  )}
                </div>
              </div>

              {/* Payment Info */}
              <div className="bg-gradient-to-r from-blue-50 to-purple-50 rounded-lg sm:rounded-xl p-3 sm:p-4 border-2 border-purple-200">
                <h3 className="text-base sm:text-lg font-bold text-gray-800 mb-2 sm:mb-3 flex items-center gap-2">
                  💳 Informasi Pembayaran
                </h3>
                <div className="grid sm:grid-cols-2 gap-3 sm:gap-4 mb-3 sm:mb-4">
                  <div>
                    <p className="text-xs sm:text-sm text-gray-600">Metode Pembayaran</p>
                    <p className="font-semibold text-sm sm:text-base uppercase text-gray-800">{selectedOrder.payment_method}</p>
                  </div>
                  <div>
                    <p className="text-xs sm:text-sm text-gray-600">Total Pembayaran</p>
                    <p className="font-bold text-2xl sm:text-3xl text-purple-600 break-words">{formatCurrency(selectedOrder.total_amount)}</p>
                  </div>
                  <div>
                    <p className="text-xs sm:text-sm text-gray-600 mb-1">Status Pembayaran</p>
                    {getPaymentBadge(selectedOrder.payment_status)}
                  </div>
                  <div>
                    <p className="text-xs sm:text-sm text-gray-600 mb-1">Bukti Pembayaran</p>
                    {selectedOrder.payment_proof_url ? (
                      <button
                        onClick={() => handleViewPaymentProof(selectedOrder)}
                        className="px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold inline-flex items-center gap-2 transition-all whitespace-nowrap"
                      >
                        <ImageIcon className="w-4 h-4" />
                        Lihat Bukti
                      </button>
                    ) : (
                      <p className="text-yellow-600 font-semibold text-xs sm:text-sm">⚠️ Belum Upload</p>
                    )}
                  </div>
                </div>

                {/* Payment Status Update Buttons */}
                <div className="pt-3 sm:pt-4 border-t border-purple-200">
                  <p className="text-xs sm:text-sm font-semibold text-gray-700 mb-2">Update Status Pembayaran:</p>
                  <div className="flex gap-2 flex-wrap">
                    {['pending', 'paid', 'failed'].map((status) => {
                      const configs = {
                        pending: { label: '⏳ Menunggu', color: 'bg-yellow-500 hover:bg-yellow-600' },
                        paid: { label: '✅ Lunas', color: 'bg-green-500 hover:bg-green-600' },
                        failed: { label: '❌ Gagal', color: 'bg-red-500 hover:bg-red-600' },
                      }
                      const config = configs[status as keyof typeof configs]
                      return (
                        <button
                          key={status}
                          onClick={() => handleUpdatePaymentStatus(selectedOrder.id, status as any)}
                          disabled={updateLoading || selectedOrder.payment_status === status}
                          className={`px-3 sm:px-5 py-1.5 sm:py-2 text-xs sm:text-sm rounded-lg font-bold text-white transition-all whitespace-nowrap ${
                            selectedOrder.payment_status === status
                              ? 'bg-gray-400 cursor-not-allowed'
                              : config.color
                          }`}
                        >
                          {config.label}
                        </button>
                      )
                    })}
                  </div>
                </div>
              </div>

              {/* Order Status Update */}
              <div className="bg-gray-50 rounded-lg sm:rounded-xl p-3 sm:p-4">
                <h3 className="text-base sm:text-lg font-bold text-gray-800 mb-2 sm:mb-3 flex items-center gap-2">
                  📦 Status Pesanan
                </h3>
                <div className="mb-2 sm:mb-3">
                  <p className="text-xs sm:text-sm text-gray-600 mb-2">Status Saat Ini:</p>
                  {getStatusBadge(selectedOrder.order_status)}
                </div>
                <div>
                  <p className="text-xs sm:text-sm font-semibold text-gray-700 mb-2">Update Status Pesanan:</p>
                  <div className="flex gap-2 flex-wrap">
                    {[
                      { value: 'pending', label: 'Menunggu', color: 'bg-yellow-500 hover:bg-yellow-600' },
                      { value: 'confirmed', label: 'Dikonfirmasi', color: 'bg-blue-500 hover:bg-blue-600' },
                      { value: 'processing', label: 'Diproses', color: 'bg-purple-500 hover:bg-purple-600' },
                      { value: 'completed', label: 'Selesai', color: 'bg-green-500 hover:bg-green-600' },
                      { value: 'cancelled', label: 'Dibatalkan', color: 'bg-red-500 hover:bg-red-600' },
                    ].map((status) => (
                      <button
                        key={status.value}
                        onClick={() => handleUpdateOrderStatus(selectedOrder.id, status.value as any)}
                        disabled={updateLoading || selectedOrder.order_status === status.value}
                        className={`px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm rounded-lg font-semibold text-white transition-all whitespace-nowrap ${
                          selectedOrder.order_status === status.value
                            ? 'bg-gray-400 cursor-not-allowed'
                            : status.color
                        }`}
                      >
                        {status.label}
                      </button>
                    ))}
                  </div>
                </div>
              </div>

              {/* Notes */}
              {selectedOrder.notes && (
                <div className="bg-yellow-50 rounded-lg sm:rounded-xl p-3 sm:p-4 border-2 border-yellow-200">
                  <h3 className="text-base sm:text-lg font-bold text-gray-800 mb-2 flex items-center gap-2">
                    📝 Catatan
                  </h3>
                  <p className="text-sm sm:text-base text-gray-700 break-words">{selectedOrder.notes}</p>
                </div>
              )}
            </div>

            <div className="p-4 sm:p-6 border-t border-gray-200 bg-gray-50">
              <button
                onClick={() => setShowDetailModal(false)}
                className="w-full px-4 sm:px-6 py-2 sm:py-3 text-sm sm:text-base bg-gray-600 hover:bg-gray-700 text-white rounded-lg sm:rounded-xl font-bold transition-all"
              >
                Tutup
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Payment Proof Modal */}
      {showPaymentProofModal && paymentProofUrl && (
        <div className="fixed inset-0 bg-black/80 backdrop-blur-sm z-[60] flex items-center justify-center p-2 sm:p-4">
          <div className="bg-white rounded-xl sm:rounded-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden animate-fadeInUp">
            <div className="p-3 sm:p-4 border-b border-gray-200 flex items-center justify-between bg-gradient-to-r from-blue-600 to-purple-600">
              <h3 className="text-lg sm:text-xl font-bold text-white">Bukti Pembayaran</h3>
              <button
                onClick={() => {
                  setShowPaymentProofModal(false)
                  setPaymentProofUrl(null)
                }}
                className="text-white hover:text-red-200 transition-all"
              >
                <X className="w-6 h-6" />
              </button>
            </div>
            <div className="p-3 sm:p-6 flex items-center justify-center bg-gray-100">
              <div className="relative w-full max-w-2xl">
                <Image
                  src={paymentProofUrl}
                  alt="Bukti Pembayaran"
                  width={800}
                  height={600}
                  className="rounded-lg sm:rounded-xl shadow-2xl w-full h-auto"
                  style={{ objectFit: 'contain' }}
                />
              </div>
            </div>
            <div className="p-3 sm:p-4 border-t border-gray-200 bg-gray-50 flex flex-col sm:flex-row gap-2 sm:gap-3">
              <a
                href={paymentProofUrl}
                target="_blank"
                rel="noopener noreferrer"
                className="flex-1 px-4 sm:px-6 py-2 sm:py-3 text-sm sm:text-base bg-blue-600 hover:bg-blue-700 text-white rounded-lg sm:rounded-xl font-bold text-center transition-all"
              >
                Buka di Tab Baru
              </a>
              <button
                onClick={() => {
                  setShowPaymentProofModal(false)
                  setPaymentProofUrl(null)
                }}
                className="px-4 sm:px-6 py-2 sm:py-3 text-sm sm:text-base bg-gray-600 hover:bg-gray-700 text-white rounded-lg sm:rounded-xl font-bold transition-all"
              >
                Tutup
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  )
}
