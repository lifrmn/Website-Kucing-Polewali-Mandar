// ============================================
// CIKAL PET CARE POLMAN - PREMIUM SCHEMA
// Enhanced E-commerce & Booking System
// SQLite Compatible (Enums as Strings)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite doesn't support native enums, so we use String types
// with application-level validation
// 
// Enum Values:
// - OrderStatus: PENDING, WAITING_VERIFICATION, PAID, PROCESSING, SHIPPED, COMPLETED, CANCELED, REFUNDED
// - PaymentStatus: PENDING, VERIFYING, PAID, FAILED, REFUNDED
// - PaymentMethod: BANK_TRANSFER, QRIS, COD
// - BookingStatus: PENDING, CONFIRMED, CHECKED_IN, CHECKED_OUT, COMPLETED, CANCELED
// - UserRole: SUPER_ADMIN, ADMIN, STAFF
// - ActivityAction: CREATE, UPDATE, DELETE, VIEW, APPROVE, REJECT



// ============================================
// PRODUCT MANAGEMENT - Enhanced with Variants
// ============================================

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  sku         String   @unique
  price       Float
  stock       Int      @default(0)
  category    String
  image_url   String?
  gallery     String?  // JSON array of image URLs
  is_active   Boolean  @default(true)
  featured    Boolean  @default(false)
  
  // SEO Fields
  meta_title       String?
  meta_description String?
  
  // Stock Management
  low_stock_alert Int @default(5)
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  variants   ProductVariant[]
  orderItems OrderItem[]
  reviews    ProductReview[]

  @@index([category])
  @@index([featured])
  @@map("products")
}

model ProductVariant {
  id          String  @id @default(uuid())
  product_id  String
  sku         String  @unique
  name        String
  attributes  String  // JSON: {"size": "M", "color": "Blue"}
  price       Float?  // Price override, null = use product price
  stock       Int     @default(0)
  is_active   Boolean @default(true)
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  
  product     Product      @relation(fields: [product_id], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  
  @@index([product_id])
  @@map("product_variants")
}

model ProductReview {
  id          String   @id @default(uuid())
  product_id  String
  customer_name String
  customer_email String?
  rating      Int
  comment     String?
  is_approved Boolean  @default(false)
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  
  @@index([product_id])
  @@index([is_approved])
  @@map("product_reviews")
}

// ============================================
// SERVICE MANAGEMENT
// ============================================

model Service {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  type        String   // consultation, grooming, vaccination, etc.
  duration    Int?     // minutes
  price       Float
  image_url   String?
  is_active   Boolean  @default(true)
  featured    Boolean  @default(false)
  
  // Booking configuration
  max_bookings_per_day Int @default(5)
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  orderItems  OrderItem[]
  bookings    ServiceBooking[]

  @@index([type])
  @@map("services")
}

model ServiceBooking {
  id              String   @id @default(uuid())
  service_id      String
  customer_id     String
  booking_date    DateTime
  booking_time    String
  pet_name        String
  pet_type        String
  notes           String?
  status          String        @default("PENDING") // BookingStatus
  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  service         Service  @relation(fields: [service_id], references: [id])
  customer        Customer @relation(fields: [customer_id], references: [id])
  
  @@index([service_id, booking_date])
  @@index([customer_id])
  @@map("service_bookings")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  password   String
  role       String   @default("ADMIN") // UserRole: SUPER_ADMIN, ADMIN, STAFF
  avatar_url String?
  is_active  Boolean  @default(true)
  
  // Activity Tracking
  last_login DateTime?
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  activityLogs ActivityLog[]

  @@index([email])
  @@map("users")
}

// ============================================
// CUSTOMER MANAGEMENT
// ============================================

model Customer {
  id         String   @id @default(uuid())
  name       String
  email      String?
  phone      String   @unique
  address    String?
  city       String?
  postal_code String?
  
  // Customer Metrics
  total_orders Int @default(0)
  total_spent  Float @default(0)
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  orders            Order[]
  penitipanBookings PenitipanBooking[]
  serviceBookings   ServiceBooking[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

// ============================================
// ORDER MANAGEMENT - Enhanced Status Flow
// ============================================

model Order {
  id                 String        @id @default(uuid())
  order_number       String        @unique
  customer_id        String
  
  // Pricing
  subtotal           Float
  shipping_cost      Float         @default(0)
  discount_amount    Float         @default(0)
  total_amount       Float
  
  // Payment
  payment_method     String
  payment_status     String        @default("PENDING") // PaymentStatus
  payment_proof_url  String?
  payment_verified_at DateTime?
  
  // Shipping
  shipping_address   String?
  shipping_city      String?
  shipping_postal    String?
  shipping_notes     String?
  tracking_number    String?
  
  // Status
  status             String        @default("PENDING") // OrderStatus
  notes              String?
  admin_notes        String?
  
  // Timestamps
  paid_at            DateTime?
  shipped_at         DateTime?
  completed_at       DateTime?
  canceled_at        DateTime?
  
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  customer           Customer      @relation(fields: [customer_id], references: [id])
  orderItems         OrderItem[]
  activityLogs       ActivityLog[]

  @@index([order_number])
  @@index([customer_id])
  @@index([status])
  @@index([payment_status])
  @@index([created_at])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  order_id    String
  product_id  String?
  variant_id  String?  // New: Product variant support
  service_id  String?
  name        String   // Store name at time of purchase
  sku         String?  // Store SKU at time of purchase
  quantity    Int
  price       Float    // Store price at time of purchase
  subtotal    Float
  
  created_at  DateTime @default(now())

  order       Order            @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [product_id], references: [id])
  variant     ProductVariant?  @relation(fields: [variant_id], references: [id])
  service     Service?         @relation(fields: [service_id], references: [id])

  @@index([order_id])
  @@map("order_items")
}

// ============================================
// PENITIPAN (PET BOARDING) SYSTEM
// ============================================

model PenitipanPackage {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  description     String?
  price_per_night Float
  features        String   // JSON array
  max_cats        Int      @default(1)
  image_url       String?
  is_active       Boolean  @default(true)
  featured        Boolean  @default(false)
  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  bookings        PenitipanBooking[]

  @@map("penitipan_packages")
}

model PenitipanBooking {
  id                   String        @id @default(uuid())
  booking_number       String        @unique
  customer_id          String
  package_id           String
  
  // Cat Information
  cat_name             String
  cat_age              String?
  cat_gender           String?
  cat_breed            String?
  cat_health_condition String?
  cat_photo_url        String?
  
  // Booking Details
  check_in_date        DateTime
  check_out_date       DateTime
  total_nights         Int
  total_price          Float
  
  // Status & Payment
  status               String        @default("PENDING") // BookingStatus
  payment_status       String        @default("PENDING") // PaymentStatus
  payment_proof_url    String?
  
  // Additional Info
  special_requests     String?
  emergency_contact    String?
  
  // Timestamps
  confirmed_at         DateTime?
  checked_in_at        DateTime?
  checked_out_at       DateTime?
  
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  customer             Customer          @relation(fields: [customer_id], references: [id])
  package              PenitipanPackage  @relation(fields: [package_id], references: [id])
  activityLogs         ActivityLog[]

  @@index([booking_number])
  @@index([customer_id])
  @@index([status])
  @@index([check_in_date, check_out_date])
  @@map("penitipan_bookings")
}

// New: Booking Capacity Management
model BookingCapacity {
  id                String   @id @default(uuid())
  date              DateTime @unique
  max_capacity      Int      @default(10)
  current_bookings  Int      @default(0)
  is_available      Boolean  @default(true)
  notes             String?
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  
  @@index([date])
  @@index([is_available])
  @@map("booking_capacities")
}

// ============================================
// BLOG & CONTENT MANAGEMENT
// ============================================

model BlogPost {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  content        String    // HTML or Markdown
  excerpt        String?
  featured_image String?
  category       String?
  tags           String?   // JSON array
  author         String    @default("Admin")
  
  // SEO
  meta_title       String?
  meta_description String?
  
  // Publishing
  is_published   Boolean   @default(false)
  published_at   DateTime?
  
  // Analytics
  view_count     Int       @default(0)
  
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([slug])
  @@index([is_published])
  @@index([category])
  @@map("blog_posts")
}

// ============================================
// TESTIMONIALS & REVIEWS
// ============================================

model Testimonial {
  id            String   @id @default(uuid())
  customer_name String
  customer_email String?
  avatar_url    String?
  rating        Int
  message       String
  service_type  String?  // product, service, penitipan
  is_approved   Boolean  @default(false)
  is_featured   Boolean  @default(false)
  
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([is_approved])
  @@index([is_featured])
  @@map("testimonials")
}

// ============================================
// SYSTEM CONFIGURATION
// ============================================

model Settings {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  type       String   @default("string") // string, number, boolean, json
  description String?
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([key])
  @@map("settings")
}

// ============================================
// ACTIVITY LOG - Audit Trail
// ============================================

model ActivityLog {
  id          String         @id @default(uuid())
  user_id     String
  entity_type String  // order, product, booking, etc.
  entity_id   String
  action      String  // ActivityAction: CREATE, UPDATE, DELETE, VIEW, APPROVE, REJECT
  description String
  metadata    String?        // JSON
  ip_address  String?
  
  // Relations (optional)
  order_id    String?
  booking_id  String?
  
  created_at  DateTime       @default(now())
  
  user        User           @relation(fields: [user_id], references: [id])
  order       Order?         @relation(fields: [order_id], references: [id])
  booking     PenitipanBooking? @relation(fields: [booking_id], references: [id])
  
  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([created_at])
  @@map("activity_logs")
}


